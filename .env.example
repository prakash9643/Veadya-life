# ──────────────────────────────────────────────────────────
# Headless Shopify Storefront API Credentials Template
# Copy this file to a new file named `.env` in the root folder
# and replace the placeholders with your actual Shopify details.
# ──────────────────────────────────────────────────────────

# 1. Your Shopify Store Domain
# Formats accepted:
# - your-shop-name (automatically appends .myshopify.com)
# - your-shop-name.myshopify.com
VITE_SHOPIFY_STORE_DOMAIN=veadya-life-sciences.myshopify.com

# 2. Your Shopify Storefront API Access Token
# IMPORTANT: This must be the PUBLIC Storefront API access token (which is safe to bundle in
# client-side Vite builds). DO NOT use the Admin API token (starts with shpat_) as it has CORS
# policies that block browser-based fetch queries and is highly insecure for frontends.
#
# To create this token:
# 1. Go to Shopify Admin -> Settings -> App and sales channels.
# 2. Click "Develop apps" -> "Create an app".
# 3. Under "Configuration", select "Storefront API integration" and check necessary scopes (e.g. read_products).
# 4. Save and install the app, then copy the "Storefront API access token" from the API credentials tab.
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=f18bfdd948add1c500dac73e7ae6be61
